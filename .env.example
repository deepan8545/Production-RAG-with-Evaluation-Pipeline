# ── LLM ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here


# NEO4J_URI=
NEO4J_USERNAME=fbf64af0
# NEO4J_PASSWORD=
NEO4J_DATABASE=fbf64af0


# ── Retrieval settings ────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
# Note: we'll use Anthropic's claude for generation,
# but OpenAI embeddings are standard. Swap to a local
# HuggingFace model below if you don't want OpenAI:
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_PROVIDER=huggingface

EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here   # only needed for embeddings

# ── Generation ────────────────────────────────────────
CLAUDE_MODEL=claude-3-5-sonnet-20241022
MAX_TOKENS=1024
TEMPERATURE=0.0

# ── Retrieval tuning ──────────────────────────────────
RETRIEVER_TOP_K=20          # candidates from hybrid retrieval
RERANKER_TOP_K=5            # chunks passed to generator after reranking
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# ── RAGAS eval gate ───────────────────────────────────
FAITHFULNESS_THRESHOLD=0.85
ANSWER_RELEVANCY_THRESHOLD=0.80
CONTEXT_PRECISION_THRESHOLD=0.75

# ── App ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
